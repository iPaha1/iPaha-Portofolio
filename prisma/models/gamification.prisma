// ─── New Enums ───────────────────────────────────────────────────────────────
enum LeaderboardType {
  WEEKLY_TOKENS
  MONTHLY_TOKENS
  ALL_TIME_TOKENS
  WEEKLY_GAMES
  MONTHLY_STREAK
  GAME_MASTER
}

enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  ALL_TIME
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum MultiplayerGameType {
  TOKEN_RACE
  CLICK_WARS
  REACTION_TOURNAMENT
  QUIZ_BATTLE
}

enum MultiplayerStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  REGISTERED
  PLAYING
  COMPLETED
  DISQUALIFIED
}

enum StoreItemType {
  TOOL_ACCESS
  FEATURE_UNLOCK
  CUSTOM_THEME
  BADGE
  BOOSTER
  MYSTERY_BOX
}

enum RedemptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}


enum MultiplayerRoomStatus {
  WAITING
  COUNTDOWN
  PLAYING
  RESULTS
  CLOSED
}
