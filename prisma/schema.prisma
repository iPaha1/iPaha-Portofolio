// ─────────────────────────────────────────────────────────────────────────────
// MEDIA LIBRARY
// ─────────────────────────────────────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

model MediaFile {
  id            String       @id @default(cuid())

  // Storage
  filename      String                       // Cloudinary slug / stored name
  originalName  String                       // Original filename from user's device
  url           String       @db.Text        // Cloudinary secure_url
  cloudinaryId  String?                      // Cloudinary public_id (needed for delete/transforms)
  thumbnailUrl  String?      @db.Text        // Auto-generated thumbnail (video/document)

  // Type & MIME
  type          MediaType    @default(IMAGE)
  mimeType      String

  // Dimensions — images & video
  width         Int?
  height        Int?
  duration      Float?                       // Seconds — video and audio

  // Metadata
  alt           String?      @db.Text
  caption       String?      @db.Text
  description   String?      @db.Text
  tags          String?      @db.Text        // JSON string[] — e.g. ["blog","hero","portrait"]

  // File size
  size          Int                          // Bytes

  // Organisation
  folderId      String?
  folder        MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  // Usage tracking — what content references this file
  usedIn        MediaUsage[]

  // Soft delete / trash
  isDeleted     Boolean      @default(false)
  deletedAt     DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("media_files")
  @@index([type])
  @@index([folderId])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([cloudinaryId])
}

model MediaFolder {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique          // URL-safe: "blog-images", "app-screenshots"
  description String?
  color       String        @default("#f59e0b")  // Folder chip colour in UI
  icon        String        @default("Folder")   // Lucide icon name
  parentId    String?

  parent      MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children    MediaFolder[] @relation("FolderTree")
  files       MediaFile[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("media_folders")
  @@index([parentId])
  @@index([slug])
}

// Tracks which content items reference a media file.
// Powers the "Used in X places" badge and prevents accidental deletions.
model MediaUsage {
  id          String    @id @default(cuid())
  fileId      String
  sourceType  String    // "blog_post" | "app" | "idea" | "tool" | "podcast" | "newsletter"
  sourceId    String    // cuid of the referencing record
  field       String    @default("")  // e.g. "coverImage", "screenshot", "avatar"
  createdAt   DateTime  @default(now())

  file        MediaFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, sourceType, sourceId, field])
  @@map("media_usage")
  @@index([fileId])
  @@index([sourceType, sourceId])
}

