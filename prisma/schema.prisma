// =============================================================================
// Social Media
// =============================================================================


enum SocialPlatform {
  TWITTER
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  THREADS
  TIKTOK
  YOUTUBE
}

// Per-user OAuth token store (one row per user, all platform tokens in one place)
model SocialTokens {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Twitter / X
  twitterToken          String?   @db.Text
  twitterRefreshToken   String?   @db.Text
  twitterTokenExpiry    DateTime?
  twitterUserId         String?

  // Facebook
  facebookToken         String?   @db.Text
  facebookTokenExpiry   DateTime?
  facebookUserId        String?

  // Instagram (via Facebook Login)
  instagramUserId       String?

  // LinkedIn
  linkedinToken         String?   @db.Text
  linkedinRefreshToken  String?   @db.Text
  linkedinTokenExpiry   DateTime?
  linkedinUserId        String?

  // Threads (via Meta)
  threadsToken          String?   @db.Text
  threadsUserId         String?

  // TikTok
  tiktokToken           String?   @db.Text
  tiktokRefreshToken    String?   @db.Text
  tiktokTokenExpiry     DateTime?
  tiktokUserId          String?

  // YouTube (Google OAuth)
  youtubeToken          String?   @db.Text
  youtubeRefreshToken   String?   @db.Text
  youtubeTokenExpiry    DateTime?
  youtubeChannelId      String?

  // User relationship
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("social_tokens")
}

// Per-user social media settings and templates
model SocialSettings {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Auto-posting toggles (when AI cron generates a post, auto-publish to these)
  autoPostTwitter       Boolean   @default(false)
  autoPostFacebook      Boolean   @default(false)
  autoPostInstagram     Boolean   @default(false)
  autoPostLinkedin      Boolean   @default(false)
  autoPostThreads       Boolean   @default(false)
  autoPostTiktok        Boolean   @default(false)
  autoPostYoutube       Boolean   @default(false)

  // Per-platform content templates (supports {title}, {url}, {excerpt} variables)
  twitterTemplate       String?   @db.Text
  facebookTemplate      String?   @db.Text
  instagramTemplate     String?   @db.Text
  linkedinTemplate      String?   @db.Text
  threadsTemplate       String?   @db.Text
  tiktokTemplate        String?   @db.Text
  youtubeTemplate       String?   @db.Text

  // Cron / auto-draft settings (JSON — matches SocialCronSettings type in code)
  cronSettings          String?   @db.Text

  // User relationship
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("social_settings")
}

model SocialConnection {
  id            String         @id @default(cuid())
  platform      SocialPlatform @unique
  handle        String?
  displayName   String?
  avatarUrl     String?
  profileUrl    String?

  // OAuth tokens (stored encrypted — use a library like @prisma/field-encryption in production)
  accessToken   String         @db.Text
  refreshToken  String?        @db.Text
  tokenExpiry   DateTime?

  // Profile stats (refreshed periodically)
  followerCount Int?
  followingCount Int?
  postCount     Int?

  // Status
  isActive      Boolean        @default(true)
  lastPostedAt  DateTime?
  lastSyncedAt  DateTime?

  // Timestamps
  connectedAt   DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  posts         SocialPost[]

  @@map("social_connections")
  @@index([platform])
  @@index([isActive])
}

model SocialPost {
  id             String         @id @default(cuid())
  connectionId   String
  platform       SocialPlatform

  // Content
  content        String         @db.Text
  mediaUrls      String?        @db.Text   // JSON string[]
  hashtags       String?        @db.Text   // JSON string[]
  linkUrl        String?                   // optional link attached to post

  // Cross-posting source (if generated from a blog post)
  blogPostId     String?

  // Platform response (filled after publishing)
  platformPostId String?                   // ID returned by the platform API
  platformUrl    String?                   // Direct URL to the published post

  // Scheduling
  scheduledFor   DateTime?
  publishedAt    DateTime?

  // Status: draft | scheduled | published | failed
  status         String         @default("draft")
  failReason     String?        @db.Text   // populated if status = failed

  // AI metadata
  isAiGenerated  Boolean        @default(false)
  aiPrompt       String?        @db.Text   // what prompt generated this

  // Engagement stats (synced from platform)
  likes          Int            @default(0)
  shares         Int            @default(0)
  comments       Int            @default(0)
  impressions    Int            @default(0)
  clicks         Int            @default(0)
  reaches        Int            @default(0)

  // Timestamps
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  connection     SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@map("social_posts")
  @@index([connectionId])
  @@index([platform])
  @@index([status])
  @@index([publishedAt])
  @@index([scheduledFor])
  @@index([isAiGenerated])
}


// =============================================================================
// DEVELOPER HUB — Personal Knowledge System
// Phase 1: Snippets · AI Prompts · Dev Commands · Error Solutions
// =============================================================================


enum HubEntryType {
  // Phase 1
  SNIPPET   // Code Snippet Vault
  PROMPT    // AI Prompt Library
  COMMAND   // Developer Command Library
  ERROR     // Error Solution Library
  // Phase 2
  NOTE      // Learning Notes / Engineering Journal
  API       // API Reference Hub
  PATTERN   // Architecture Pattern Library
  TEMPLATE  // Template Library
  PLAYBOOK  // Developer Playbooks
  RESOURCE  // Resource Library
}

enum HubLanguage {
  // General
  PLAINTEXT
  BASH
  MARKDOWN
  // Web
  HTML
  CSS
  JAVASCRIPT
  TYPESCRIPT
  JSX
  TSX
  // Backend
  PYTHON
  RUST
  GO
  JAVA
  CSHARP
  PHP
  RUBY
  // Data
  SQL
  PRISMA
  GRAPHQL
  JSON
  YAML
  // Config
  DOCKERFILE
  ENV
  TOML
  // Other
  REGEX
  OTHER
}


// ─── UNIFIED HUB ENTRY ───────────────────────────────────────────────────────
// Single table for all Phase 1 entry types.
// type-specific fields are stored in typed JSON columns.
// This makes global search trivial and the schema lean.

model HubEntry {
  id          String       @id @default(cuid())
  type        HubEntryType

  // ── Universal fields ──────────────────────────────────────────────────────
  title       String
  description String?      @db.Text
  content     String       @db.LongText  // main payload: code | prompt | command | solution
  tags        String?      @db.Text      // JSON string[]
  category    String?                    // free-text: "Prisma" | "React" | "Git" | "Docker" etc.
  isFavourite Boolean      @default(false)
  isPinned    Boolean      @default(false)
  copyCount   Int          @default(0)   // how many times copied — surfaces actually useful entries
  viewCount   Int          @default(0)

  // ── SNIPPET-specific ──────────────────────────────────────────────────────
  language    HubLanguage? @default(PLAINTEXT)  // syntax highlighting
  framework   String?                            // "Next.js" | "React" | "Express" etc.

  // ── PROMPT-specific ───────────────────────────────────────────────────────
  aiModel     String?                // "claude-sonnet" | "gpt-4o" | "gemini" etc.
  exampleOutput String?  @db.LongText // optional sample output to preview

  // ── ERROR-specific ────────────────────────────────────────────────────────
  errorMessage  String?  @db.Text    // raw error message / stack trace snippet
  solution      String?  @db.LongText // step-by-step fix
  technology    String?              // "Next.js 14" | "Prisma 5" | "Node 20" etc.


  // ── NOTE ──────────────────────────────────────────────────────────────────
  references    String?  @db.Text      // JSON string[] of URLs
  difficulty    String?               // "Beginner" | "Intermediate" | "Advanced" | "Expert"

  // ── API ───────────────────────────────────────────────────────────────────
  httpMethod      String?             // "GET" | "POST" | "PUT" | "PATCH" | "DELETE"
  endpointUrl     String?  @db.Text
  requestExample  String?  @db.LongText
  responseExample String?  @db.LongText
  apiHeaders      String?  @db.Text   // JSON Record<string, string>
  authType        String?             // "Bearer Token" | "API Key" | "Basic Auth" | "None"

  // ── PATTERN ───────────────────────────────────────────────────────────────
  advantages    String?  @db.LongText
  disadvantages String?  @db.LongText
  useCases      String?  @db.LongText
  relatedTech   String?  @db.Text     // JSON string[]
  diagramUrl    String?

  // ── TEMPLATE ──────────────────────────────────────────────────────────────
  templateType  String?               // "README" | "API Documentation" | "Bug Report" etc.

  // ── PLAYBOOK ──────────────────────────────────────────────────────────────
  steps          String?  @db.LongText  // JSON PlaybookStep[]
  estimatedTime  String?               // "~30 min" | "1-2 hours"

  // ── RESOURCE ──────────────────────────────────────────────────────────────
  resourceUrl   String?  @db.Text
  resourceType  String?               // "DOCUMENTATION" | "COURSE" | "ARTICLE" | "VIDEO" | "TOOL" | "BOOK" | "PODCAST"
  rating        Int?                  // 1-5
  author        String?

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hub_entries")
  @@index([type])
  @@index([isFavourite])
  @@index([isPinned])
  @@index([category])
  @@index([language])
  @@index([createdAt])
  @@index([copyCount])
  // Full-text search index (MySQL FULLTEXT — add manually after migration if needed)
  // @@index([title, description, content]) -- not supported by Prisma directly for FULLTEXT
}



// ─── HUB AI ASSISTANT CONVERSATION ──────────────────────────────────────────
// Stores conversation history for the Hub AI Assistant.
// Each session is a series of messages. Sessions are scoped to admin user.

model HubConversation {
  id        String   @id @default(cuid())
  title     String?                       // auto-generated from first message
  messages  String   @db.LongText         // JSON HubMessage[]
  context   String?  @db.Text             // JSON string[] of entry IDs used in last answer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hub_conversations")
  @@index([createdAt])
}





// =============================================================================
// JOB APPLICATION TRACKER
// =============================================================================

model JobSeekerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique

  // Display
  displayName       String
  avatarUrl         String?
  headline          String?
  bio               String?  @db.Text
  location          String?
  currentRole       String?
  targetRole        String?
  targetSectors     String?  @db.Text
  yearsExperience   Int?

  // Social links (private — only visible to user)
  linkedinUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  twitterUrl        String?

  // Privacy settings
  isPublicProfile   Boolean  @default(true)
  showCompanyNames  Boolean  @default(true)
  showOnLadder      Boolean  @default(true)
  ladderDisplayName String?

  // Employment status
  isEmployed        Boolean  @default(false)
  employedAt        DateTime?
  employedCompany   String?
  employedRole      String?

  // Gamification
  xpPoints          Int      @default(0)
  level             Int      @default(1)
  streakDays        Int      @default(0)
  lastActivityDate  DateTime?
  totalApplications Int      @default(0)
  // applicationCount  Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Link to Tools model
  toolId          String?
  Tool              Tool?                @relation(fields: [toolId], references: [id], onDelete: Cascade)

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications      JobApplication[]
  badges            UserBadge[]
  discussions       Discussion[]
  discussionReplies DiscussionReply[]
  discussionLikes   DiscussionLike[]
  sharedProgress    SharedProgress[]
  ladderEntry       LadderEntry?

  @@map("job_seeker_profiles")
}

model JobApplication {
  id              String            @id @default(cuid())
  profileId       String

  // Core fields
  jobTitle        String
  company         String?
  hideCompany     Boolean           @default(false)
  sector          String?
  location        String?
  workType        WorkType          @default(FULL_TIME)
  workMode        WorkMode          @default(HYBRID)
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String            @default("GBP")
  jobUrl          String?

  // Status tracking
  status          ApplicationStatus @default(APPLIED)
  appliedAt       DateTime          @default(now())
  statusUpdatedAt DateTime          @default(now())
  statusHistory   String?           @db.Text

  // Notes & reflection
  notes           String?           @db.Text
  coverLetterUsed Boolean           @default(false)
  resumeVersion   String?

  // Interview reflection journal
  interviewNotes  String?           @db.Text
  whatWentWell    String?           @db.Text
  whatToImprove   String?           @db.Text
  interviewDate   DateTime?
  interviewRound  Int?

  // Follow-up tracking
  followUpDate    DateTime?
  followedUp      Boolean           @default(false)

  // AI coaching cache
  aiInsight       String?           @db.Text

  // Outcome
  outcome         String?
  rejectionReason String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  profile         JobSeekerProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("job_applications")
  @@index([profileId])
  @@index([status])
  @@index([appliedAt])
  @@index([sector])
}

model LadderEntry {
  id                 String           @id @default(cuid())
  profileId          String           @unique

  totalApplications  Int              @default(0)
  activeApplications Int              @default(0)
  interviews         Int              @default(0)
  offers             Int              @default(0)
  rejections         Int              @default(0)
  lastApplicationAt  DateTime?
  rank               Int?

  weeklyApplications Int              @default(0)
  weeklyUpdatedAt    DateTime?

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  profile            JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("ladder_entries")
  @@index([totalApplications])
  @@index([rank])
}

model UserBadge {
  id        String           @id @default(cuid())
  profileId String
  type      BadgeType
  awardedAt DateTime         @default(now())
  metadata  String?

  profile   JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("user_badges")
  @@unique([profileId, type])
  @@index([profileId])
}

model Discussion {
  id          String             @id @default(cuid())
  profileId   String
  category    DiscussionCategory @default(GENERAL)
  title       String
  content     String             @db.Text
  isAnonymous Boolean            @default(false)
  isPinned    Boolean            @default(false)
  isResolved  Boolean            @default(false)
  viewCount   Int                @default(0)
  likeCount   Int                @default(0)
  replyCount  Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  profile     JobSeekerProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  replies     DiscussionReply[]
  likes       DiscussionLike[]

  @@map("discussions")
  @@index([profileId])
  @@index([category])
  @@index([createdAt])
  @@index([likeCount])
}

model DiscussionReply {
  id              String           @id @default(cuid())
  discussionId    String
  profileId       String
  content         String           @db.Text
  isAnonymous     Boolean          @default(false)
  likeCount       Int              @default(0)
  isMarkedHelpful Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  discussion      Discussion       @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  profile         JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("discussion_replies")
  @@index([discussionId])
  @@index([profileId])
}

model DiscussionLike {
  id           String           @id @default(cuid())
  discussionId String
  profileId    String
  createdAt    DateTime         @default(now())

  discussion   Discussion       @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  profile      JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("discussion_likes")
  @@unique([discussionId, profileId])
}

model SharedProgress {
  id         String           @id @default(cuid())
  profileId  String
  platform   String
  message    String           @db.Text
  stats      String           @db.Text
  shareCount Int              @default(1)
  createdAt  DateTime         @default(now())

  profile    JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("shared_progress")
  @@index([profileId])
}


enum ApplicationStatus {
  WISHLIST        // saved to apply later
  APPLIED         // submitted application
  PHONE_SCREEN    // phone/initial screen scheduled or done
  INTERVIEW       // interview stage (any round)
  ASSESSMENT      // technical test / take-home
  FINAL_ROUND     // final interview
  OFFER           // offer received
  ACCEPTED        // offer accepted — user is employed
  REJECTED        // rejected at any stage
  WITHDRAWN       // user withdrew
  GHOSTED         // no response after reasonable time
}

enum WorkType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
  APPRENTICESHIP
}

enum WorkMode {
  ON_SITE
  HYBRID
  REMOTE
}

enum DiscussionCategory {
  GENERAL
  ADVICE
  SUCCESS_STORY
  VENT
  QUESTION
  RESOURCE
  INTERVIEW_PREP
  SALARY
}

enum BadgeType {
  FIRST_APPLICATION
  TEN_APPLICATIONS
  FIFTY_APPLICATIONS
  HUNDRED_APPLICATIONS
  FIRST_INTERVIEW
  RESILIENCE
  STREAK_7
  STREAK_30
  EMPLOYED
  COMMUNITY_HELPER
  TOP_SHARER
}



// =============================================================================
// AI CV ANALYSER PRO
// Stores saved analyses, cover letters, and interview sessions for signed-in users.
// =============================================================================
 
// ─── Saved CV Analysis ────────────────────────────────────────────────────────
 
model CvAnalysis {
  id            String      @id @default(cuid())
  userId        String
 
  // Label & context
  label         String                        // e.g. "Software Engineer @ Google"
  jobTitle      String?
  companyName   String?
  targetRole    String?
  roleMode      CVRoleMode  @default(GENERAL)
 
  // Input data
  cvText        String      @db.Text          // the CV that was analysed (up to 15k chars)
  jobDescription String?    @db.Text          // job description if provided
 
  // Score snapshot (denormalised for quick dashboard queries)
  overallScore  Int         @default(0)
  atsScore      Int         @default(0)
  keywordScore  Int         @default(0)
  languageScore Int         @default(0)
  structureScore Int        @default(0)
  jobMatchScore Int         @default(0)
 
  // Full analysis JSON (all sections, rewrites, suggestions, etc.)
  analysisJson  String      @db.LongText      // JSON.stringify(CVAnalysis)
 
  // Metadata
  isStarred     Boolean     @default(false)   // user can star favourite analyses
  notes         String?     @db.Text          // user's personal notes on this analysis
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Link to Tool model
  toolId        String?
  tool          Tool?      @relation(fields: [toolId], references: [id], onDelete: Cascade)
 
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverLetters      CvCoverLetter[]
  interviewSessions CvInterviewSession[]
 
  @@map("cv_analyses")
  @@index([userId])
  @@index([createdAt])
  @@index([overallScore])
}
 
// ─── Cover Letters ────────────────────────────────────────────────────────────
 
model CvCoverLetter {
  id          String            @id @default(cuid())
  analysisId  String
  userId      String
 
  content     String            @db.Text      // the generated cover letter text
  style       CoverLetterStyle  @default(PROFESSIONAL)
  jobTitle    String?
  companyName String?
 
  // User edits (if they edited the generated letter)
  editedContent String?         @db.Text
  isEdited      Boolean         @default(false)
 
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
 
  analysis    CvAnalysis        @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId],    references: [id], onDelete: Cascade)
 
  @@map("cv_cover_letters")
  @@index([analysisId])
  @@index([userId])
}
 
// ─── Interview Sessions ───────────────────────────────────────────────────────
// One per analysis — stores the 12 questions + answers for study/revision.
 
model CvInterviewSession {
  id          String   @id @default(cuid())
  analysisId  String
  userId      String
 
  jobTitle    String?
  questions   String   @db.LongText          // JSON: InterviewQuestion[] (with modelAnswer)
 
  // Study progress: which questions the user has marked as "ready"
  markedReady String?  @db.Text              // JSON: number[] of question indices
  studyCount  Int      @default(0)           // how many times they've opened the study tab
  lastStudied DateTime?
 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
 
  analysis    CvAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId],     references: [id], onDelete: Cascade)
 
  @@map("cv_interview_sessions")
  @@index([analysisId])
  @@index([userId])
}

enum CoverLetterStyle {
  PROFESSIONAL
  CREATIVE
  CONCISE
}
 
enum CVRoleMode {
  GENERAL
  TECH
  FINANCE
  GRADUATE
  BUSINESS
  HEALTHCARE
  CREATIVE
}



// =============================================================================
// QR CODE GENERATOR
// =============================================================================

model QrCode {
  id          String      @id @default(cuid())
  userId      String

  label       String                        // user-given name, e.g. "My Portfolio QR"
  type        QRCodeType  @default(URL)
  content     String      @db.Text          // raw encoded content (URL, vCard, WiFi string…)
  qrData      String      @db.Text          // the final string encoded into the QR matrix

  // Design settings (serialised JSON of QRDesign object)
  designJson  String?     @db.Text

  // Dynamic QR — the actual QR encodes a short redirect URL
  // Users can edit `destination` at any time without reprinting
  isDynamic   Boolean     @default(false)
  dynamicId   String?     @unique           // 6-char alphanumeric short code
  destination String?     @db.Text          // where the dynamic QR redirects to

  // Visibility
  isPublic    Boolean     @default(false)

  // Analytics (denormalised for fast queries)
  totalScans  Int         @default(0)
  lastScanned DateTime?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Link to Tool model
  toolId        String?
  tool          Tool?      @relation(fields: [toolId], references: [id], onDelete: Cascade)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans       QrScan[]

  @@map("qr_codes")
  @@index([userId])
  @@index([dynamicId])
  @@index([createdAt])
}

// ─── Scan Event ───────────────────────────────────────────────────────────────
// Recorded each time a dynamic QR code is scanned

model QrScan {
  id         String   @id @default(cuid())
  qrCodeId   String
  scannedAt  DateTime @default(now())

  // Analytics metadata
  device     String?              // "mobile" | "desktop" | "tablet"
  country    String?              // ISO country code (from Vercel headers)
  ip         String?              // hashed / anonymised IP
  userAgent  String?  @db.Text
  referrer   String?

  qrCode     QrCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  @@map("qr_scans")
  @@index([qrCodeId])
  @@index([scannedAt])
}

enum QRCodeType {
  URL
  LINKEDIN
  INSTAGRAM
  TWITTER
  VCARD
  EMAIL
  SMS
  PHONE
  WIFI
  PAYMENT
  TEXT
}



