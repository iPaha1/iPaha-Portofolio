}

datasource db {
  provider = "mysql"
}

// =============================================================================
// isaacpaha.com — Comprehensive Database Schema
// Personal Brand Platform · Media Hub · Startup Portfolio · Community
// =============================================================================
// Stack: Next.js · Prisma ORM · MySQL
// Author: Isaac Paha — iPaha Ltd
// =============================================================================


// =============================================================================
// USERS
// =============================================================================

// Site visitor and registered user
model User {
  id                String    @id @default(cuid())
  clerkId        String?   @unique // Clerk authentication ID
  email             String    @unique
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?

  // Profile
  username          String?   @unique
  displayName       String
  firstName         String?
  lastName          String?
  bio               String?   @db.Text
  avatarUrl         String?
  websiteUrl        String?
  twitterHandle     String?
  linkedinUrl       String?
  githubHandle      String?

  // Role & permissions
  role              UserRole  @default(READER)
  isActive          Boolean   @default(true)
  isBanned          Boolean   @default(false)
  isGameTermsAccepted Boolean   @default(false)
  isGameBanned         Boolean   @default(false)
  isToolsTermsAccepted Boolean   @default(false)
  bannedAt          DateTime?
  banReason         String?

  // Geographic & device metadata
  country           String?
  countryCode       String?
  region            String?
  city              String?
  timezone          String?
  ipAddress         String?
  userAgent         String?

  // Source tracking
  referralSource    String?
  referralMedium    String?
  referralCampaign  String?

  // Engagement scores (cached)
  totalArticlesRead Int       @default(0)
  totalComments     Int       @default(0)
  totalLikes        Int       @default(0)
  reputationScore   Int       @default(0)

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastSeenAt        DateTime  @default(now())
  lastLoginAt       DateTime?

  // Auth
  passwordHash      String?
  authProvider      String?
  authProviderId    String?

  // Relationships
  sessions          UserSession[]
  comments          BlogComment[]
  reactions         BlogReaction[]
  bookmarks         Bookmark[]
  likes             PostLike[]
  newsletter        NewsletterSubscriber?
  notifications     Notification[]
  questionAsked     AskIsaacQuestion[]    @relation("QuestionAskedBy")
  readingHistory    ReadingHistory[]
  toolUsage         ToolUsageLog[]

  socialTokens      SocialTokens?
  socialSettings    SocialSettings?

  // Tools
  jobSeekerProfile      JobSeekerProfile?

  // AI CV Analyser relations
  cvAnalyses        CvAnalysis[]
  cvCoverLetters    CvCoverLetter[]
  cvInterviewSessions CvInterviewSession[]

  // Qr Code
  qrCodes     QrCode[]

  // Debt Recovery Planner
  debtProfile       DebtProfile?
  repaymentPlans    RepaymentPlan[]
  paymentLogs       PaymentLog[]
  debtCoachMessages DebtCoachMessage[]

  // First Home Planner
  homeOwnerShipPlan   HomeOwnershipPlan?

  // Smart Shopping List
  shoppingLists        ShoppingList[]
  listCollaborations   ListCollaborator[]

  // Comparative Scripture Explorer 
  scriptureExplorations  ScriptureExploration[]
  scriptureNotes         ScriptureNote[]

  // Math Understanding Engine 
  mathQueries           MathQuery[]
  mathPracticeSessions  MathPracticeSession[]
  mathLearningProgress  MathLearningProgress?

  // Physics Understanding Engine 
  physicsQueries          PhysicsQuery[]
  physicsPracticeSessions PhysicsPracticeSession[]
  physicsLearningProgress PhysicsLearningProgress?

  // Chemistry Understanding Engine
  chemistryQueries          ChemistryQuery[]
  chemistryPracticeSessions ChemistryPracticeSession[]
  chemistryLearningProgress ChemistryLearningProgress?

  // Kids Birthday Planner
  party                     Party[]

  // Gamification & achievements
  userAchievements         UserAchievement[]
  gameParticipation    GameParticipation[]
  tokenWallet           TokenWallet?
  tokenTransactions       TokenTransaction[]
  userStreaks            UserStreak[]
  gameSettings            GameSettings?
  leaderboardEntries       LeaderboardEntry[]
  participants            MultiplayerParticipant[]
  tokenRedemptions         TokenRedemption[]
  referralsAsReferrer   Referral[]          @relation("Referrer")
  referralsAsReferred   Referral?           @relation("Referred")
  referralCode          ReferralCode?

  // Token Rush Challenge relations
  rushChallengesCreated     TokenRushChallenge[] @relation("ChallengeCreator")
  tokenRushCashouts         TokenRushCashout[]


  @@map("users")
  @@index([email])
  @@index([username])
  @@index([role])
  @@index([createdAt])
  @@index([countryCode])
}

// Session management
model UserSession {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

enum UserRole {
  READER
  SUBSCRIBER
  ADMIN
  SUPER_ADMIN
}



// ─────────────────────────────────────────────────────────────────────────────
// APPS (Products)
// ─────────────────────────────────────────────────────────────────────────────

model App {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  tagline      String
  description  String    @db.Text
  fullDescription String? @db.LongText
  category     String
  status       AppStatus @default(IN_DEVELOPMENT)
  emoji        String    @default("📱")
  coverImage   String?
  logoImage    String?
  accentColor  String    @default("#f59e0b")
  isPublished  Boolean   @default(false)
  isFeatured   Boolean   @default(false)
  isNew        Boolean   @default(false)
  comingSoon     Boolean  @default(false)

  problemSolved  String? @db.LongText
  businessModel  String? @db.LongText
  targetUsers   String? @db.LongText
  
  // Company
  company      String    // "iPaha Ltd" | "iPahaStores Ltd" | "Okpah Ltd"
  companyFlag  String    @default("🇬🇧")

  // Links
  appUrl       String?
  githubUrl    String?
  playStoreUrl String?
  appStoreUrl  String?

  // Tech stack — JSON array of strings
  techStack    String    @db.Text

  // Metrics
  userCount    Int       @default(0)
  viewCount    Int       @default(0)
  likeCount    Int       @default(0)

  // Dates
  launchDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  screenshots  AppScreenshot[]
  changelog    AppChangelog[]
  updates      AppUpdate[]
  techItems    AppTechItem[]

  @@map("apps")
  @@index([slug])
  @@index([status])
  @@index([company])
  @@index([isFeatured])
}

enum AppStatus {
  COMING_SOON
  IN_DEVELOPMENT
  BETA
  LIVE
  DEPRECATED
}

enum ToolStatus {
  LIVE
  BETA
  COMING_SOON
}

model AppScreenshot {
  id        String   @id @default(cuid())
  appId     String
  url       String
  alt       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("app_screenshots")
  @@index([appId])
}

model AppChangelog {
  id          String   @id @default(cuid())
  appId       String
  version     String
  title       String
  description String   @db.Text
  type        String   @default("feature") // feature | fix | improvement | breaking
  releasedAt  DateTime
  createdAt   DateTime @default(now())

  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("app_changelog")
  @@index([appId])
  @@index([releasedAt])
}

// Build in public update log
model AppUpdate {
  id          String   @id @default(cuid())
  appId       String
  title       String
  content     String   @db.LongText
  dayNumber   Int?
  metrics     String?  @db.Text // JSON: { users: 10, mrr: 50 }
  isPublished Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  app         App     @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("app_updates")
  @@index([appId])
  @@index([publishedAt])
}

model AppTechItem {
  id          String   @id @default(cuid())
  appId   String
  name        String
  category    String?
  iconUrl     String?
  url         String?

  app         App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("project_tech_items")
  @@index([appId])
}

// enum AppStatus {
//   CONCEPT
//   IN_PROGRESS
//   LAUNCHED
//   PAUSED
//   DEPRECATED
// }

enum AppCategory {
  WEB_APP
  MOBILE_APP
  API
  OPEN_SOURCE
  SAAS
  TOOL
  RESEARCH
  OTHER
}


// =============================================================================
// IDEAS LAB
// =============================================================================

model Idea {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  summary     String       @db.Text
  content     String       @db.LongText
  coverImage  String?
  category    IdeaCategory @default(TECH)
  status      IdeaStatus   @default(CONCEPT)
  tags        String?      @db.Text // JSON string[]
  isPublished Boolean      @default(false)
  publishedAt DateTime?
  isFeatured  Boolean      @default(false)

  viewCount   Int          @default(0)
  likeCount   Int          @default(0)
  commentCount Int         @default(0)

  metaTitle       String?
  metaDescription String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("ideas")
  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([isPublished])
}

enum IdeaCategory {
  TECH
  AI
  BUSINESS
  SOCIETY
  AFRICA
  FINTECH
  EDUCATION
  PHILOSOPHY
  OTHER
}

enum IdeaStatus {
  CONCEPT
  EXPLORING
  DEVELOPING
  SHELVED
  LAUNCHED
}


// =============================================================================
// TOOLS
// =============================================================================

model Tool {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  tagLine         String       @db.Text
  description     String       @db.Text
  longDescription String?      @db.LongText
  features        Json?        // List of features for the tool
  icon            String?
  tags            String?      @db.Text
  coverImage      String?
  category        ToolCategory @default(AI)
  status          ToolStatus  @default(LIVE)
  isPublic        Boolean      @default(true)
  isPremium       Boolean      @default(false)
  isFeatured      Boolean      @default(false)
  isInteractive   Boolean      @default(false)
  isActive        Boolean      @default(true)

  version         String?      @default("1.0.0")
  apiEndpoint     String?
  config          String?      @db.Text // JSON

  viewCount       Int          @default(0)
  usageCount      Int          @default(0)
  ratingAvg       Float?
  ratingCount     Int          @default(0)

  metaTitle       String?
  metaDescription String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  usageLogs       ToolUsageLog[]

  cvAnalyses          CvAnalysis[]
  qrCodes             QrCode[]
  debtRecoveryPlanner        DebtProfile[]
  jobApplicationPlanner   JobSeekerProfile[]
  firstHomePlanner        HomeOwnershipPlan[]
  smartShoppingList       ShoppingList[]
  scriptureExplorer       ScriptureExploration[]
  mathEngine              MathQuery[]
  physicsEngine           PhysicsQuery[]
  

  @@map("tools")
  @@index([slug])
  @@index([category])
  @@index([isActive])
}



model ToolUsageLog {
  id           String   @id @default(cuid())
  toolId       String
  userId       String?
  ipAddress    String?
  inputData    String?  @db.Text
  processingMs Int?
  wasSuccess   Boolean  @default(true)
  errorMsg     String?
  country      String?
  createdAt    DateTime @default(now())

  tool         Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("tool_usage_logs")
  @@index([toolId])
  @@index([userId])
  @@index([createdAt])
}

enum ToolCategory {
  AI
  PRODUCTIVITY
  CAREER
  STARTUP
  EDUCATION
  WRITING
  OTHER
}


// =============================================================================
// NEWSLETTER
// =============================================================================

model NewsletterSubscriber {
  id                  String           @id @default(cuid())
  email               String           @unique
  userId              String?          @unique
  firstName           String?
  lastName            String?
  displayName         String?

  status              NewsletterStatus @default(ACTIVE)
  subscribedAt        DateTime         @default(now())
  unsubscribedAt      DateTime?
  unsubscribeReason   String?
  confirmedAt         DateTime?
  confirmToken        String?          @unique

  // Preferences
  weeklyDigest        Boolean          @default(true)
  newArticleAlerts    Boolean          @default(true)
  projectUpdates      Boolean          @default(true)
  communityPosts      Boolean          @default(true)
  milestoneAlerts     Boolean          @default(false)

  source              String?
  segment             String?
  tags                String?          @db.Text // JSON string[]

  country             String?
  countryCode         String?
  timezone            String?

  // Engagement stats
  totalEmailsReceived Int              @default(0)
  totalEmailsOpened   Int              @default(0)
  totalLinksClicked   Int              @default(0)
  lastOpenedAt        DateTime?
  lastClickedAt       DateTime?
  engagementScore     Float            @default(0)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user                User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  emailEvents         EmailEvent[]

  @@map("newsletter_subscribers")
  @@index([email])
  @@index([status])
  @@index([confirmedAt])
  @@index([subscribedAt])
}

model NewsletterEdition {
  id          String   @id @default(cuid())
  issueNumber Int      @unique
  title       String
  slug        String   @unique
  preview     String   @db.Text   // The preview line shown in email clients
  content     String   @db.LongText  // Tiptap JSON
  contentHtml String?  @db.LongText

  // Stats
  sentAt      DateTime?
  recipientCount Int    @default(0)
  openCount   Int       @default(0)
  clickCount  Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("newsletter_editions")
  @@index([issueNumber])
  @@index([sentAt])
}

model NewsletterCampaign {
  id                String         @id @default(cuid())
  title             String
  subject           String
  previewText       String?
  htmlContent       String         @db.LongText
  textContent       String         @db.LongText
  type              CampaignType   @default(REGULAR)
  status            CampaignStatus @default(DRAFT)

  scheduledAt       DateTime?
  sentAt            DateTime?

  segments          String?        @db.Text // JSON
  totalRecipients   Int            @default(0)

  totalSent         Int            @default(0)
  totalOpened       Int            @default(0)
  totalClicked      Int            @default(0)
  totalUnsubscribed Int            @default(0)
  totalBounced      Int            @default(0)
  openRate          Float?
  clickRate         Float?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  emailEvents       EmailEvent[]

  @@map("newsletter_campaigns")
  @@index([status])
  @@index([sentAt])
}

model EmailEvent {
  id             String               @id @default(cuid())
  subscriberId   String
  campaignId     String?
  type           EmailEventType
  emailAddress   String
  ipAddress      String?
  userAgent      String?
  link           String?
  bounceType     String?
  bounceReason   String?
  createdAt      DateTime             @default(now())

  subscriber     NewsletterSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  campaign       NewsletterCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@map("email_events")
  @@index([subscriberId])
  @@index([campaignId])
  @@index([type])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  subject     String
  htmlContent String   @db.LongText
  textContent String   @db.LongText
  variables   String?  @db.Text // JSON: available template variables
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

enum NewsletterStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum CampaignType {
  REGULAR
  WELCOME
  ANNOUNCEMENT
  DIGEST
  MILESTONE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum EmailEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  FAILED
}


// =============================================================================
// MEDIA — PODCAST
// =============================================================================

model PodcastEpisode {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String        @db.Text
  showNotes       String?       @db.LongText
  thumbnailImage  String?

  audioUrl        String?
  videoUrl        String?
  youtubeId       String?
  duration        Int?          // Seconds
  episodeNumber   Int?
  season          Int?          @default(1)

  type            PodcastType   @default(SOLO)
  status          EpisodeStatus @default(DRAFT)
  publishedAt     DateTime?

  guestName       String?
  guestTitle      String?
  guestImage      String?
  guestUrl        String?

  playCount       Int           @default(0)
  likeCount       Int           @default(0)

  metaTitle       String?
  metaDescription String?
  tags            String?       @db.Text // JSON

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  chapters        PodcastChapter[]

  @@map("podcast_episodes")
  @@index([slug])
  @@index([status])
  @@index([publishedAt])
}

model PodcastChapter {
  id          String         @id @default(cuid())
  episodeId   String
  title       String
  startSecs   Int
  createdAt   DateTime       @default(now())

  episode     PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@map("podcast_chapters")
  @@index([episodeId])
}

enum PodcastType {
  SOLO
  INTERVIEW
  PANEL
  READING
}

enum EpisodeStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}


// =============================================================================
// ASK ISAAC / NOW PAGE / TIMELINE / KNOWLEDGE LIBRARY
// =============================================================================

model AskIsaacQuestion {
  id              String         @id @default(cuid())
  userId          String?
  askerName       String
  askerEmail      String?
  question        String         @db.Text
  context         String?        @db.Text
  status          QuestionStatus @default(SUBMITTED)
  isPublic        Boolean        @default(false)
  isAnonymous     Boolean        @default(false)
  ipAddress       String?

  answeredPostId  String?
  answeredAt      DateTime?
  answerSummary   String?        @db.Text

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  askedBy         User?          @relation("QuestionAskedBy", fields: [userId], references: [id], onDelete: SetNull)

  @@map("ask_isaac_questions")
  @@index([status])
  @@index([isPublic])
  @@index([createdAt])
}

enum QuestionStatus {
  SUBMITTED
  UNDER_REVIEW
  ANSWERED_PUBLICLY
  ANSWERED_PRIVATELY
  REJECTED
}

// "What I'm Thinking About Now" — updated monthly
model NowPage {
  id          String   @id @default(cuid())
  month       Int
  year        Int
  title       String
  content     String   @db.LongText
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("now_pages")
  @@unique([month, year])
  @@index([year])
  @@index([isPublished])
}

// Personal journey timeline
model TimelineEvent {
  id          String       @id @default(cuid())
  year        Int
  month       Int?
  title       String
  description String       @db.Text
  type        TimelineType @default(MILESTONE)
  icon        String?
  imageUrl    String?
  link        String?
  isHighlight Boolean      @default(false)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@map("timeline_events")
  @@index([year])
  @@index([type])
}

enum TimelineType {
  EDUCATION
  CAREER
  PROJECT
  PERSONAL
  MILESTONE
  AWARD
}

// Personal knowledge library — books, papers, courses
model KnowledgeItem {
  id            String        @id @default(cuid())
  title         String
  author        String?
  type          KnowledgeType
  url           String?
  imageUrl      String?
  description   String?       @db.Text
  notes         String?       @db.LongText
  rating        Int?
  isRecommended Boolean       @default(false)
  isFeatured    Boolean       @default(false)
  finishedAt    DateTime?
  startedAt     DateTime?
  tags          String?       @db.Text // JSON
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("knowledge_items")
  @@index([type])
  @@index([isRecommended])
}

enum KnowledgeType {
  BOOK
  PAPER
  COURSE
  VIDEO
  PODCAST
  ARTICLE
  TOOL
  OTHER
}


// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  data      String?          @db.Text // JSON
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  COMMENT_REPLY
  NEW_COMMENT_ON_FOLLOWED
  NEW_ARTICLE
  NEW_FOLLOWER
  MENTION
  NEWSLETTER
  MILESTONE
  SYSTEM
}


// =============================================================================
// ANALYTICS & CACHING
// =============================================================================

// Site-wide daily statistics
model SiteStatistic {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date @unique

  pageViews          Int      @default(0)
  uniqueVisitors     Int      @default(0)
  sessions           Int      @default(0)
  bounceRate         Float?
  avgSessionSecs     Int?

  newPosts           Int      @default(0)
  totalComments      Int      @default(0)
  totalReactions     Int      @default(0)
  totalShares        Int      @default(0)
  totalBookmarks     Int      @default(0)

  newUsers           Int      @default(0)
  newSubscribers     Int      @default(0)
  unsubscribes       Int      @default(0)
  toolUsageCount     Int      @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("site_statistics")
  @@index([date])
}

// Geographic analytics
model CountryStatistic {
  id               String   @id @default(cuid())
  countryCode      String   @unique
  countryName      String
  flagEmoji        String?

  totalVisitors    Int      @default(0)
  totalPageViews   Int      @default(0)
  totalUsers       Int      @default(0)
  totalSubscribers Int      @default(0)
  totalComments    Int      @default(0)

  todayVisitors    Int      @default(0)
  weekVisitors     Int      @default(0)
  monthVisitors    Int      @default(0)

  lastUpdated      DateTime @default(now())

  @@map("country_statistics")
  @@index([totalVisitors])
}

// Trending score cache
// Score = (likes * 3 + comments * 5 + views) / hours_since_post
model TrendingCache {
  id        String   @id @default(cuid())
  postId    String   @unique
  score     Float    @default(0)
  rank      Int?
  period    String   @default("24h") // "24h" | "7d" | "30d"
  updatedAt DateTime @default(now())

  @@map("trending_cache")
  @@index([score])
  @@index([rank])
}

// Article recommendation cache
model RecommendationCache {
  id                String   @id @default(cuid())
  sourcePostId      String
  recommendedPostId String
  score             Float    @default(0)
  reason            String?  // "same_tag" | "same_category" | "popular"
  createdAt         DateTime @default(now())
  expiresAt         DateTime

  @@map("recommendation_cache")
  @@unique([sourcePostId, recommendedPostId])
  @@index([sourcePostId])
  @@index([score])
}


// =============================================================================
